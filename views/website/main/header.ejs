<style>
  .card-item {
    left: 50%;
    transform: translateX(-50%);
    bottom: 0;
    transform-origin: bottom center;
  }
</style>

<script>
  (function() {
    const cardElements = [
      document.getElementById('card-1'),
      document.getElementById('card-2'),
      document.getElementById('card-3'),
      document.getElementById('card-4')
    ];
    
    // Initial configuration: indices in the stack (0=top, 1=middle, 2=bottom, 3=hidden)
    let cardIndices = [0, 1, 2, 3];
    let isAnimating = false;

    const positionStyles = [
      { scale: 1, y: 12, opacity: 1, zIndex: 30, pointerEvents: 'auto' },
      { scale: 0.95, y: -16, opacity: 0.9, zIndex: 20, pointerEvents: 'none' },
      { scale: 0.9, y: -44, opacity: 0.8, zIndex: 10, pointerEvents: 'none' },
      { scale: 0.8, y: -72, opacity: 0, zIndex: 0, pointerEvents: 'none' }
    ];

    function updateCardPositions() {
      cardIndices.forEach((stackIndex, arrayIndex) => {
        const el = cardElements[arrayIndex];
        if (!el) return;

        const style = positionStyles[stackIndex] || positionStyles[3];

        el.style.zIndex = style.zIndex;
        el.style.opacity = style.opacity;
        el.style.pointerEvents = style.pointerEvents;
        el.style.transform = `translateX(-50%) translateY(${style.y}px) scale(${style.scale})`;
      });
    }

    // Run initially to position the cards
    updateCardPositions();

    const animateBtn = document.getElementById('animate-btn');
    if (animateBtn) {
      animateBtn.addEventListener('click', function() {
        if (isAnimating) return;
        isAnimating = true;

        // Find which card is currently at the top (stack index 0)
        const topCardArrayIndex = cardIndices.indexOf(0);
        const topEl = cardElements[topCardArrayIndex];

        if (topEl) {
          // 1. Move the top card out (drop down exit animation)
          topEl.style.transform = 'translateX(-50%) translateY(340px) scale(1)';
          topEl.style.opacity = '0';
          topEl.style.zIndex = '40';
        }

        // 2. Animate other cards up one level
        cardIndices.forEach((stackIndex, arrayIndex) => {
          if (arrayIndex === topCardArrayIndex) return; // Top card is handled separately

          let newStackIndex = stackIndex - 1;
          cardIndices[arrayIndex] = newStackIndex;

          const el = cardElements[arrayIndex];
          if (!el) return;

          const style = positionStyles[newStackIndex];
          el.style.zIndex = style.zIndex;
          el.style.opacity = style.opacity;
          el.style.pointerEvents = style.pointerEvents;
          el.style.transform = `translateX(-50%) translateY(${style.y}px) scale(${style.scale})`;
        });

        // 3. After exit finishes, place the former top card at the bottom of the stack
        setTimeout(() => {
          cardIndices[topCardArrayIndex] = 3; // Put at index 3 (hidden/bottom)
          
          const style = positionStyles[3];
          topEl.style.zIndex = style.zIndex;
          topEl.style.opacity = style.opacity;
          topEl.style.pointerEvents = style.pointerEvents;
          topEl.style.transform = `translateX(-50%) translateY(${style.y}px) scale(${style.scale})`;

          isAnimating = false;
        }, 500); // Duration matches CSS transition
      });
    }
  })();
</script>